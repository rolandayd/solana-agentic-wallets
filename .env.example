# Solana Agentic Wallet — Environment Configuration
# Copy to .env and fill in values before running

# REQUIRED: Master secret for AES-256-GCM key encryption
# In production: use a strong random value from a secrets manager
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_SECRET=your-strong-random-secret-here

# Solana network: devnet | testnet | mainnet-beta
NETWORK=devnet

# Optional: Custom RPC endpoint (for mainnet, use a private RPC like Helius/QuickNode)
# RPC_ENDPOINT=https://api.devnet.solana.com

# Optional: Keystore directory (default: ./keystore)
# KEYSTORE_PATH=./keystore
